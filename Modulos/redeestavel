#!/bin/bash
# REDE ESTAVEL - ajustes seguros para SSH em rede com internet valida
# Nao burla operadora, franquia, bloqueio ou autenticacao de rede.

LOGDIR="/var/log/sshplus"
LOG="$LOGDIR/rede_estavel.log"
mkdir -p "$LOGDIR"

verde="\033[1;32m"; amarelo="\033[1;33m"; vermelho="\033[1;31m"; branco="\033[1;37m"; fim="\033[0m"

precisa_root() {
  if [ "$(id -u)" != "0" ]; then
    echo -e "${vermelho}Execute como root.${fim}"
    exit 1
  fi
}

cmd_exists() { command -v "$1" >/dev/null 2>&1; }

backup() {
  local f="$1"
  [ -f "$f" ] && cp "$f" "$f.bak.$(date +%Y%m%d-%H%M%S)" 2>/dev/null
}

set_sshd_option() {
  local key="$1"
  local value="$2"
  local file="/etc/ssh/sshd_config"
  grep -qiE "^[#[:space:]]*${key}[[:space:]]+" "$file" \
    && sed -i -E "s|^[#[:space:]]*${key}[[:space:]]+.*|${key} ${value}|I" "$file" \
    || echo "${key} ${value}" >> "$file"
}

restart_service() {
  local svc="$1"
  if systemctl list-unit-files 2>/dev/null | grep -q "^${svc}\.service"; then
    systemctl restart "$svc" >/dev/null 2>&1
  else
    service "$svc" restart >/dev/null 2>&1
  fi
}

liberar_porta() {
  local p="$1"
  [ -z "$p" ] && return
  if cmd_exists ufw; then
    ufw allow "${p}/tcp" >/dev/null 2>&1
  fi
  if cmd_exists iptables; then
    iptables -C INPUT -p tcp --dport "$p" -j ACCEPT >/dev/null 2>&1 || \
    iptables -I INPUT -p tcp --dport "$p" -j ACCEPT >/dev/null 2>&1
  fi
}

precisa_root
clear
echo -e "${verde}SSH PLUS - REDE ESTAVEL${fim}"
echo -e "${amarelo}Ajusta estabilidade para Wi-Fi/dados moveis com internet valida.${fim}"
echo "Inicio: $(date)" >> "$LOG"

# SSH seguro e estavel
if [ -f /etc/ssh/sshd_config ]; then
  backup /etc/ssh/sshd_config
  set_sshd_option "PasswordAuthentication" "yes"
  set_sshd_option "TCPKeepAlive" "yes"
  set_sshd_option "ClientAliveInterval" "30"
  set_sshd_option "ClientAliveCountMax" "6"
  set_sshd_option "UseDNS" "no"
  set_sshd_option "MaxStartups" "50:30:200"
  set_sshd_option "LoginGraceTime" "60"
  sshd -t >> "$LOG" 2>&1
  if [ "$?" = "0" ]; then
    restart_service ssh || restart_service sshd
    echo -e "${verde}OpenSSH ajustado e reiniciado.${fim}"
  else
    echo -e "${vermelho}sshd_config apresentou erro. Backup foi mantido.${fim}"
  fi
fi

# Keepalive do kernel para reduzir queda de sessao em rede movel
cat >/etc/sysctl.d/99-sshplus-rede-estavel.conf <<'EOF'
net.ipv4.tcp_keepalive_time=60
net.ipv4.tcp_keepalive_intvl=15
net.ipv4.tcp_keepalive_probes=4
net.ipv4.tcp_fin_timeout=15
net.ipv4.tcp_tw_reuse=1
net.ipv4.ip_forward=1
EOF
sysctl --system >> "$LOG" 2>&1

# Resolver DNS padrao quando systemd-resolved existe
if [ -d /etc/systemd/resolved.conf.d ]; then
  mkdir -p /etc/systemd/resolved.conf.d
fi
if cmd_exists systemctl && systemctl list-unit-files 2>/dev/null | grep -q '^systemd-resolved.service'; then
  mkdir -p /etc/systemd/resolved.conf.d
  cat >/etc/systemd/resolved.conf.d/sshplus-dns.conf <<'EOF'
[Resolve]
DNS=1.1.1.1 8.8.8.8
FallbackDNS=9.9.9.9 8.8.4.4
EOF
  systemctl restart systemd-resolved >/dev/null 2>&1
fi

# Libera portas comuns do proprio projeto sem mudar payload de operadora
PORTAS="22 80 443 8080 3128 8799 7300"
if [ -f /etc/ssh/sshd_config ]; then
  EXTRA=$(grep -iE '^[[:space:]]*Port[[:space:]]+[0-9]+' /etc/ssh/sshd_config | awk '{print $2}')
  PORTAS="$PORTAS $EXTRA"
fi
for p in $PORTAS; do liberar_porta "$p"; done

# Reinicia servicos comuns se existirem
for svc in ssh sshd squid squid3 stunnel4 openvpn cron; do
  if systemctl list-unit-files 2>/dev/null | grep -q "^${svc}\.service"; then
    systemctl restart "$svc" >/dev/null 2>&1
  fi
done

echo "Fim: $(date)" >> "$LOG"
echo -e "${verde}Concluido.${fim}"
echo -e "${branco}Log: ${LOG}${fim}"
echo -e "${amarelo}Obs: precisa existir internet/rede autorizada no aparelho do cliente.${fim}"
read -p "Pressione ENTER para voltar..."
